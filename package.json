{
  "name": "reonic-challenge",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "postinstall": "cd backend && npm install && cd ../frontend && npm install",
    "setup": "npm install && cd backend && npx prisma generate && npx prisma migrate dev --name init",
    "dev:backend": "cd backend && npx ts-node src/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently -c \"cyan.bold,green.bold\" -n \"BACKEND,FRONTEND\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "test": "cd backend && npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fabienstrauss/reonic-challenge.git"
  },
  "private": true,
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.2"
  }
}
