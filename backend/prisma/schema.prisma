generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SimulationRun {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Input paramter
  numChargepoints   Int
  arrivalMultiplier Float
  consumptionKWh    Float
  chargingPowerKW   Float

  // Outputs
  totalEnergyKWh        Float
  theoreticalMaxPowerKW Float
  actualMaxPowerKW      Float
  concurrencyFactor     Float

  // Data per tick
  chargepointTicks Json

  // Performance Index
  @@index([createdAt])
  // Map name to snake_case name convention
  @@map("simulation_runs")
}
